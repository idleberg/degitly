{
	"name": "degitly",
	"version": "0.1.2",
	"description": "degit clone powered by gitly, downloads Git repositories without cloning them",
	"license": "MIT",
	"author": "Jan T. Sott",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/idleberg/degitly.git"
	},
	"keywords": [
		"scaffolding",
		"template",
		"gitly",
		"degit"
	],
	"type": "module",
	"bin": {
		"degitly": "./bin/index.mjs",
		"dg": "./bin/index.mjs"
	},
	"engines": {
		"node": ">=20"
	},
	"files": [
		"bin/",
		"LICENSE",
		"README.md"
	],
	"scripts": {
		"build": "tsdown",
		"dev": "npm run build -- --watch",
		"lint": "concurrently --prefix-colors blue,green,magenta npm:lint:*",
		"lint:biome": "biome check",
		"lint:e18e": "e18e-cli analyze",
		"prepack": "npm run build",
		"publish:jsr": "deno publish",
		"publish:npm": "np --any-branch",
		"test": "vitest run"
	},
	"dependencies": {
		"commander": "^14.0.3",
		"gitly": "^3.2.4",
		"kleur": "^4.1.5",
		"log-symbols": "^7.0.1"
	},
	"devDependencies": {
		"@commitlint/cli": "^20.5.3",
		"@commitlint/config-conventional": "^20.5.3",
		"@idleberg/configs": "^0.4.2",
		"@types/node": "^24.10.1",
		"@vitest/coverage-v8": "^4.1.5",
		"concurrently": "^9.2.1",
		"np": "^11.2.0",
		"tsdown": "0.21.10",
		"tsup": "^8.5.1",
		"typescript": "^6.0.3",
		"vitest": "^4.1.5"
	},
	"pnpm": {
		"onlyBuiltDependencies": [
			"lefthook"
		]
	},
	"packageManager": "pnpm@10.33.4+sha512.1c67b3b359b2d408119ba1ed289f34b8fc3c6873412bec6fd264fbdc82489e510fcbecb9ce9d22dae7f3b76269d8441046014bdca53b9979cd7a561ad631b800"
}
